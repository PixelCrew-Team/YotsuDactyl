<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Archivos | <%= displayTitle %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root { --bg: #050505; --card: #0f0f0f; --blue: #007bff; }
        body { margin: 0; background: var(--bg); color: white; font-family: 'Segoe UI', sans-serif; }
        .header-server { padding: 20px 40px; background: var(--card); border-bottom: 1px solid rgba(255,255,255,0.05); }
        .container { padding: 40px; }
        .file-row { padding: 12px 25px; border-bottom: 1px solid #1a1a1a; display: flex; justify-content: space-between; }
    </style>
</head>
<body>
    <div class="header-server">
        <h1><%= server.name %></h1>
        <div style="display:flex; gap:10px;">
            <a href="/server/<%= server.id %>" style="color:gray; text-decoration:none;">Console</a>
            <a href="#" style="color:white; text-decoration:none; border-bottom: 2px solid var(--blue);">Files</a>
        </div>
    </div>
    <div class="container">
        <div style="background: var(--card); border-radius: 8px; border: 1px solid #222;">
            <% if (files.length === 0) { %>
                <div style="padding: 20px; text-align: center; color: gray;">Este directorio está vacío.</div>
            <% } else { %>
                <% files.forEach(file => { %>
                    <div class="file-row">
                        <span><i class="<%= file.isDirectory ? 'fas fa-folder' : 'fas fa-file' %>"></i> <%= file.name %></span>
                        <span><%= file.size %></span>
                    </div>
                <% }); %>
            <% } %>
        </div>
    </div>
</body>
</html>