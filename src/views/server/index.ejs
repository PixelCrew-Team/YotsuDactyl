<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Consola | <%= displayTitle %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root { --bg: #050505; --card: #0f0f0f; --blue: #007bff; --green: #28a745; --red: #dc3545; }
        body { margin: 0; background: var(--bg); color: white; font-family: 'Segoe UI', sans-serif; }
        .header-server { padding: 20px 40px; background: var(--card); border-bottom: 1px solid rgba(255,255,255,0.05); }
        .nav-tabs { display: flex; gap: 5px; }
        .nav-tab { padding: 10px 20px; color: rgba(255,255,255,0.6); text-decoration: none; border-radius: 5px; font-size: 14px; }
        .nav-tab.active { border-bottom: 2px solid var(--blue); color: white; }
        .container { padding: 20px 40px; display: grid; grid-template-columns: 3fr 1fr; gap: 20px; }
        .console-box { background: #000; border-radius: 8px; border: 1px solid #222; height: 450px; display: flex; flex-direction: column; }
        .console-output { flex-grow: 1; padding: 15px; font-family: monospace; font-size: 13px; overflow-y: auto; }
        .console-input { background: #111; border: none; border-top: 1px solid #222; padding: 12px; color: white; outline: none; }
        .stat-card { background: var(--card); padding: 20px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.05); margin-bottom: 15px; display: flex; justify-content: space-between; align-items: center; }
        .stat-val { font-size: 18px; font-weight: bold; }
    </style>
</head>
<body>
    <div class="header-server">
        <h1><%= server.name %></h1>
        <div class="nav-tabs">
            <a href="/server/<%= server.id %>" class="nav-tab active">Console</a>
            <a href="/server/<%= server.id %>/files" class="nav-tab">Files</a>
            <a href="/server/<%= server.id %>/startup" class="nav-tab">Startup</a>
        </div>
    </div>
    <div class="container">
        <div class="left">
            <div style="display: flex; gap: 10px; margin-bottom: 20px;">
                <button class="btn" style="background: var(--green); padding: 10px 20px; border:none; color:white; border-radius:5px; cursor:pointer;">START</button>
                <button class="btn" style="background: var(--red); padding: 10px 20px; border:none; color:white; border-radius:5px; cursor:pointer;">STOP</button>
            </div>
            <div class="console-box">
                <div class="console-output" id="console">Conectando con el contenedor...</div>
                <input type="text" class="console-input" placeholder="Enviar comando...">
            </div>
        </div>
        <div class="right">
            <div class="stat-card">
                <div><small>CPU</small><div class="stat-val">0% / <%= server.cpu %>%</div></div>
                <i class="fas fa-microchip"></i>
            </div>
            <div class="stat-card">
                <div><small>RAM</small><div class="stat-val">0MB / <%= server.ram %>MB</div></div>
                <i class="fas fa-memory"></i>
            </div>
            <div class="stat-card">
                <div><small>DISCO</small><div class="stat-val">0MB / <%= server.disk %>MB</div></div>
                <i class="fas fa-save"></i>
            </div>
        </div>
    </div>
</body>
</html>
