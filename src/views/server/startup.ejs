<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Startup | <%= displayTitle %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root { --bg: #050505; --card: #0f0f0f; --blue: #007bff; }
        body { margin: 0; background: var(--bg); color: white; font-family: 'Segoe UI', sans-serif; }
        .container { padding: 40px; }
        .card { background: var(--card); padding: 25px; border-radius: 8px; border: 1px solid #222; margin-bottom: 20px; }
        input { width: 100%; padding: 12px; background: #1a1a1a; border: 1px solid #333; color: white; border-radius: 5px; }
    </style>
</head>
<body>
    <div class="header-server">
        <h1 style="padding-left:40px;"><%= server.name %></h1>
    </div>
    <div class="container">
        <div class="card">
            <h3>Comando de Inicio</h3>
            <div style="background:#000; padding:15px; border:1px solid var(--blue); font-family:monospace; color:#00ffcc;">
                <%= server.startup_command %>
            </div>
        </div>
        <div class="card">
            <h3>Variables de Entorno</h3>
            <label>Variable Principal</label>
            <input type="text" value="<%= server.main_variable %>">
            <button style="margin-top:20px; background:var(--blue); color:white; border:none; padding:10px 20px; border-radius:5px; cursor:pointer;">GUARDAR</button>
        </div>
    </div>
</body>
</html>