<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>YotsuDactyl - Login</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --bg-galaxy: #020617;
            --card-bg: rgba(30, 41, 59, 0.7);
            --neon-blue: #38bdf8;
            --text-main: #f8fafc;
        }
        body {
            background: radial-gradient(circle at top, #0f172a, var(--bg-galaxy));
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            margin: 0;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            background: var(--card-bg);
            border: 1px solid rgba(56, 189, 248, 0.2);
            border-radius: 15px;
            padding: 40px;
            width: 100%;
            max-width: 400px;
            backdrop-filter: blur(10px);
            text-align: center;
            box-shadow: 0 0 20px rgba(0,0,0,0.5);
        }
        .input-group {
            margin-bottom: 20px;
            text-align: left;
        }
        .input-group label {
            display: block;
            margin-bottom: 8px;
            color: var(--neon-blue);
            font-size: 14px;
        }
        .input-field {
            width: 100%;
            padding: 12px;
            background: rgba(15, 23, 42, 0.8);
            border: 1px solid rgba(56, 189, 248, 0.2);
            border-radius: 8px;
            color: white;
            outline: none;
            box-sizing: border-box;
        }
        .input-field:focus {
            border-color: var(--neon-blue);
        }
        .btn-neon {
            width: 100%;
            background: transparent;
            border: 1px solid var(--neon-blue);
            color: var(--neon-blue);
            padding: 12px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
            text-shadow: 0 0 5px var(--neon-blue);
            transition: 0.3s;
        }
        .btn-neon:hover {
            background: var(--neon-blue);
            color: var(--bg-galaxy);
        }
        .error-msg {
            background: rgba(239, 68, 68, 0.2);
            color: #ef4444;
            padding: 10px;
            border-radius: 8px;
            margin-bottom: 20px;
            border: 1px solid #ef4444;
            font-size: 13px;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <h1 style="color: var(--neon-blue); margin-bottom: 10px;">YOTSUDACTYL</h1>
        <p style="opacity: 0.6; margin-bottom: 30px;">Inicia sesión para continuar</p>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="error-msg"><%= error %></div>
        <% } %>

        <form action="/auth/login" method="POST">
            <div class="input-group">
                <label>Usuario / Email</label>
                <input type="text" name="username" class="input-field" required>
            </div>
            <div class="input-group">
                <label>Contraseña</label>
                <input type="password" name="password" class="input-field" required>
            </div>
            <button type="submit" class="btn-neon">ENTRAR AL PANEL</button>
        </form>
    </div>
</body>
</html>