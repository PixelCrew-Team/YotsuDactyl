<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Nodos | <%= displayTitle %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root { --bg: #050505; --card: #0f0f0f; --blue: #007bff; --accent: #00ffcc; }
        body { margin: 0; background: var(--bg); color: white; font-family: 'Segoe UI', sans-serif; display: flex; }
        .sidebar { width: 260px; background: var(--card); border-right: 1px solid rgba(255,255,255,0.05); position: fixed; height: 100vh; }
        .nav-item { padding: 12px 25px; display: block; color: rgba(255,255,255,0.7); text-decoration: none; font-size: 14px; }
        .main { margin-left: 260px; padding: 40px; width: 100%; min-height: 100vh; display: flex; flex-direction: column; }
        
        .node-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; margin-top: 20px; }
        .node-card { background: var(--card); border: 1px solid rgba(255,255,255,0.05); padding: 25px; border-radius: 12px; transition: 0.3s; }
        .node-card:hover { border-color: var(--blue); }
        
        .stat-line { display: flex; justify-content: space-between; font-size: 13px; margin: 5px 0; color: rgba(255,255,255,0.6); }
        .btn-create { background: var(--blue); color: white; padding: 12px 25px; border-radius: 5px; text-decoration: none; font-weight: bold; width: fit-content; margin-top: auto; border: none; cursor: pointer; }
        .badge { background: rgba(0, 255, 204, 0.1); color: var(--accent); padding: 2px 8px; border-radius: 4px; font-size: 10px; border: 1px solid var(--accent); }
        .empty { text-align: center; padding: 50px; color: rgba(255,255,255,0.2); }
    </style>
</head>
<body>
    <div class="sidebar">
        <div style="padding: 25px; text-align: center;"><h3><%= displayTitle %></h3></div>
        <a href="/admin" class="nav-item"><i class="fas fa-home"></i> Inicio</a>
        <a href="/admin/servers" class="nav-item"><i class="fas fa-server"></i> Servidores</a>
        <a href="/admin/nodes" class="nav-item" style="color: var(--blue);"><i class="fas fa-network-wired"></i> Nodos</a>
    </div>

    <div class="main">
        <h1>Nodos y Ubicaciones</h1>
        
        <div class="node-grid">
            <% if (nodes.length === 0) { %>
                <div class="divider" style="grid-column: span 2;">
                    <p class="empty">No hay nodos configurados en la base de datos.</p>
                </div>
            <% } else { %>
                <% nodes.forEach(node => { %>
                    <div class="node-card">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <h3><%= node.name %></h3>
                            <span class="badge">ACTIVO</span>
                        </div>
                        <p style="font-size: 12px; color: gray;">FQDN/IP: <%= node.ip_address %></p>
                        
                        <div class="stat-line">
                            <span>RAM:</span>
                            <span><%= node.ram %> MB</span>
                        </div>
                        <div class="stat-line">
                            <span>Disco:</span>
                            <span><%= node.disk %> MB</span>
                        </div>
                        
                        <a href="/admin/nodes/edit/<%= node.id %>" style="display: block; margin-top: 15px; color: var(--blue); text-decoration: none; font-size: 12px;">Configurar Parámetros →</a>
                    </div>
                <% }); %>
            <% } %>
        </div>

        <button class="btn-create" style="margin-top: 30px;">AÑADIR NUEVO NODO</button>

        <footer style="margin-top: auto; text-align: center; font-size: 12px; color: rgba(255,255,255,0.2); padding-top: 40px;">
            Copyright &copy; 2026 <a href="<%= siteUrl %>" target="_blank" style="color: var(--blue); text-decoration: none;"><%= siteName %></a>
        </footer>
    </div>
</body>
</html>