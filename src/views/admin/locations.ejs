<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Ubicaciones | <%= displayTitle %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root { --bg: #050505; --card: #0f0f0f; --blue: #007bff; }
        body { margin: 0; background: var(--bg); color: white; font-family: 'Segoe UI', sans-serif; display: flex; }
        .sidebar { width: 260px; background: var(--card); border-right: 1px solid rgba(255,255,255,0.05); position: fixed; height: 100vh; }
        .main { margin-left: 260px; padding: 40px; width: 100%; min-height: 100vh; display: flex; flex-direction: column; }
        .loc-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px; margin-top: 20px; }
        .loc-card { background: var(--card); border: 1px solid rgba(0, 123, 255, 0.2); padding: 20px; border-radius: 10px; }
        .btn-create { background: var(--blue); color: white; padding: 12px 25px; border-radius: 5px; text-decoration: none; font-weight: bold; width: fit-content; margin-top: auto; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div style="padding: 25px; text-align: center;"><h3><%= displayTitle %></h3></div>
        <a href="/admin" style="padding: 12px 25px; display: block; color: rgba(255,255,255,0.7); text-decoration: none; font-size: 14px;"><i class="fas fa-home"></i> Inicio</a>
        <a href="/admin/nodes" style="padding: 12px 25px; display: block; color: var(--blue); text-decoration: none; font-size: 14px;"><i class="fas fa-network-wired"></i> Nodos / Loc</a>
    </div>
    <div class="main">
        <h1>Ubicaciones</h1>
        <div class="loc-grid">
            <div class="loc-card">
                <i class="fas fa-map-marker-alt" style="color: var(--blue);"></i>
                <strong style="margin-left: 10px;">Localhost</strong>
                <p style="font-size: 12px; color: rgba(255,255,255,0.4); margin-bottom: 0;">Ubicación por defecto del sistema.</p>
            </div>
        </div>
        <a href="#" class="btn-create" style="margin-top: 20px;">AÑADIR UBICACIÓN</a>
        <footer style="margin-top: auto; text-align: center; font-size: 12px; color: rgba(255,255,255,0.2); padding-top: 40px;">
            Copyright &copy; 2026 <a href="<%= siteUrl %>" target="_blank" style="color: var(--blue); text-decoration: none;"><%= siteName %></a>
        </footer>
    </div>
</body>
</html>
