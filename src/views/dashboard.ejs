<%- include('partials/header') %>

<div class="container">
    <h1 style="margin-bottom: 30px;">Tus Servidores</h1>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
        <% if (servers.length > 0) { %>
            <% servers.forEach(server => { %>
                <div class="card">
                    <h3 style="color: #38bdf8;"><%= server.name %></h3>
                    <p style="opacity: 0.7;">Status: <span style="color: #22c55e;">Online</span></p>
                    <a href="/server/<%= server.id %>" class="btn-neon" style="text-decoration: none; display: inline-block; margin-top: 10px;">Gestionar</a>
                </div>
            <% }); %>
        <% } else { %>
            <div class="card">
                <p>No tienes servidores activos todavía.</p>
                <button class="btn-neon">+ Crear Nuevo</button>
            </div>
        <% } %>
    </div>
</div>

<%- include('partials/footer') %>