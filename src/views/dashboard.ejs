<%- include('partials/header') %>

<div class="container" style="max-width: 1200px; margin: 0 auto;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px;">
        <h1 style="font-size: 28px; font-weight: 600;">Tus Servidores</h1>
        <button class="btn-neon" style="font-size: 14px;">+ NUEVO SERVIDOR</button>
    </div>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 25px;">
        <% if (typeof servers !== 'undefined' && servers.length > 0) { %>
            <% servers.forEach(server => { %>
                <div class="card">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px;">
                        <h3 style="color: #38bdf8; margin: 0; font-size: 18px;"><%= server.name %></h3>
                        <span style="background: rgba(34, 197, 94, 0.2); color: #22c55e; padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: bold;">ONLINE</span>
                    </div>
                    <p style="opacity: 0.6; font-size: 13px; margin-bottom: 20px;">ID: <%= server.identifier %></p>
                    <div style="display: flex; gap: 10px;">
                        <a href="/server/<%= server.id %>" class="btn-neon" style="text-decoration: none; flex: 1; text-align: center; font-size: 13px;">CONSOLA</a>
                        <a href="/server/<%= server.id %>/settings" class="btn-neon" style="text-decoration: none; padding: 10px; width: 40px; text-align: center;"><i class="fas fa-cog"></i></a>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <div class="card" style="grid-column: 1 / -1; text-align: center; padding: 50px;">
                <i class="fas fa-server" style="font-size: 40px; color: rgba(56, 189, 248, 0.2); margin-bottom: 20px;"></i>
                <p style="opacity: 0.7;">No se encontraron servidores en tu cuenta.</p>
                <button class="btn-neon" style="margin-top: 15px;">DESPLEGAR PRIMER SERVIDOR</button>
            </div>
        <% } %>
    </div>
</div>

</div>
</body>
</html>