<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Perfil | <%= displayTitle %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root { --bg: #050505; --card: #0f0f0f; --blue: #007bff; }
        body { margin: 0; background: var(--bg); color: white; font-family: 'Segoe UI', sans-serif; }
        .container { padding: 40px; max-width: 600px; margin: auto; }
        .card { background: var(--card); padding: 25px; border-radius: 8px; border: 1px solid #222; }
        input { width: 100%; padding: 12px; background: #1a1a1a; border: 1px solid #333; color: white; border-radius: 5px; margin: 10px 0; }
        .btn { background: var(--blue); color: white; border: none; padding: 10px 20px; border-radius: 5px; cursor: pointer; width: 100%; font-weight: bold; }
    </style>
</head>
<body>
    <div class="container">
        <div class="card">
            <h2 style="margin-top:0;">Configuración de Cuenta</h2>
            <label>Nombre de Usuario</label>
            <input type="text" value="<%= user.username %>" readonly>
            <label>Correo Electrónico</label>
            <input type="email" value="<%= user.email %>">
            <label>Nueva Contraseña</label>
            <input type="password" placeholder="Dejar en blanco para no cambiar">
            <button class="btn">ACTUALIZAR PERFIL</button>
        </div>
    </div>
</body>
</html>
